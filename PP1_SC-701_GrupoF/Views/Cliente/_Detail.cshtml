<div class="modal fade" id="modalDetalleCliente" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Detalle Cliente</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="DetalleClienteId" />

                <div class="row">
                    <div class="col-md-6"><strong>Nombre:</strong> <span id="dNombre"></span></div>
                    <div class="col-md-6"><strong>Apellidos:</strong> <span id="dApellidos"></span></div>
                    <div class="col-md-6"><strong>Identificación:</strong> <span id="dIdentificacion"></span></div>
                    <div class="col-md-6"><strong>Email:</strong> <span id="dEmail"></span></div>
                    <div class="col-md-12"><strong>Dirección:</strong> <span id="dDireccion"></span></div>
                </div>

                <hr />

                <h5>Teléfonos</h5>

                <form id="formAgregarTelefono">
                    <div class="row">
                        <div class="col-md-5 mb-2">
                            <input type="text" class="form-control" id="TelNumero" name="Numero" placeholder="####-####" required />
                        </div>
                        <div class="col-md-5 mb-2">
                            <input type="text" class="form-control" id="TelTipo" name="Tipo" placeholder="Celular / Casa" required />
                        </div>
                        <div class="col-md-2 mb-2">
                            <button type="button" class="btn btn-success w-100" id="btnAgregarTelefono">Agregar</button>
                        </div>
                    </div>
                </form>

                <table class="table table-striped" id="tblTelefonos">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Número</th>
                            <th>Tipo</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>

        </div>
    </div>
</div>
